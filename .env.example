# Copy to .env and fill in values. See README for local development notes.

PORT=8081
# Optional; when set, callback URL uses http://HOST/AUTH0_CALLBACK_URL
HOST=

AUTH0_DOMAIN=
AUTH0_AUDIENCE=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Path segment only when HOST is set; host:port/path when running locally without HOST
AUTH0_CALLBACK_URL=callback

TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
